# ── Bot ──
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_IDS=123456789,987654321

# ── Channels ──
TELEGRAM_CLIENT_CHANNEL_ID=-100xxxxxxxxx
TELEGRAM_AGENT_CHANNEL_ID=-100xxxxxxxxx
TELEGRAM_PAYMENT_LOG_CHANNEL_ID=-100xxxxxxxxx

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── OpenAI ──
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── App ──
WEBHOOK_URL=https://yourdomain.com/webhook
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ── Payment ──
UPI_ID=yourname@upi
PAYMENT_VERIFICATION_ENABLED=true
